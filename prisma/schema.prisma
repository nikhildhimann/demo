generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
}

enum PropertyStatus {
  AVAILABLE
  SOLD
  RENTED
  DRAFT
}

enum PropertyType {
  APARTMENT
  HOUSE
  VILLA
  TOWNHOUSE
  COMMERCIAL
  LAND
  PLOT
}

enum PropertyPurpose {
  BUY
  RENT
  SELL
}

enum LeadStatus {
  NEW
  CONTACTED
  INTERESTED
  SITE_VISIT
  NEGOTIATION
  CONVERTED
  LOST
  SPAM
}

enum LeadPriority {
  HOT
  WARM
  COLD
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?
  name          String?
  role          UserRole  @default(ADMIN)
  image         String?
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  properties    Property[]
  accounts      Account[]
  sessions      Session[]
}

model Property {
  id          String         @id @default(cuid())
  title       String
  slug        String         @unique
  description String
  price       Float
  status      PropertyStatus
  type        PropertyType
  purpose     PropertyPurpose @default(BUY)
  bedrooms    Int
  bathrooms   Int
  area        Float
  size        Float?
  location    String?
  suburb      String?
  address     String
  city        String
  state       String
  zip         String
  zipCode     String?
  country     String
  amenities   String[]
  featured    Boolean        @default(false)
  images      Image[]
  enquiries   Enquiry[]
  authorId    String
  author      User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?
  agentPhone  String?
  agentEmail  String?
  agentName   String?

  @@index([status])
  @@index([type])
  @@index([purpose])
  @@index([city])
  @@index([location])
  @@index([featured])
  @@index([deletedAt])
}

model Image {
  id         String   @id @default(cuid())
  url        String
  publicId   String?
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  order      Int      @default(0)
}

model Enquiry {
  id                   String        @id @default(cuid())
  name                 String
  email                String?
  phone                String
  propertyId           String?
  property             Property?     @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  message              String?
  status               LeadStatus    @default(NEW)
  priority             LeadPriority  @default(WARM)
  source               String        @default("Website Contact")
  budget               String?
  preferredLocation    String?
  preferredType        String?
  interestType         String?
  interestLocation     String?
  interestBudget       String?
  interestPropertyType String?
  notes                String?
  followUpDate         DateTime?
  preferredContactTime String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([status])
  @@index([priority])
  @@index([source])
  @@index([propertyId])
  @@index([createdAt])
  @@index([followUpDate])
}

model SiteSettings {
  id                    String   @id @default(cuid())
  businessName          String
  tagline               String?
  phone                 String?
  whatsappNumber        String?
  email                 String?
  address               String?
  city                  String?
  state                 String?
  country               String?
  logoUrl               String?
  faviconUrl            String?
  primaryDomain         String?
  facebookUrl           String?
  twitterUrl            String?
  instagramUrl          String?
  linkedinUrl           String?
  youtubeUrl            String?
  defaultSeoTitle       String?
  defaultSeoDescription String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// NextAuth Models (for Prisma Adapter)
model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
