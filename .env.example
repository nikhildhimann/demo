# Database Configuration
# You must use a PostgreSQL database. For local development, you can use Docker or a local PostgreSQL instance.
# For production, we recommend Neon, Supabase, or Render.
DATABASE_URL="postgresql://user:password@localhost:5432/realestate?schema=public"

# NextAuth Configuration
# Run `openssl rand -base64 32` to generate a secret
NEXTAUTH_SECRET="your_generated_secret_here"
NEXTAUTH_URL="http://localhost:3000"

# Public Site URL (recommended for production canonical links and notifications)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Cloudinary Integration (Image Uploads)
# Create a free account at cloudinary.com to get these credentials
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Email Notifications (optional, but recommended for production leads)
NOTIFICATION_EMAIL="admin@example.com"
EMAIL_FROM="Real Estate Leads <no-reply@example.com>"

# Resend Integration (optional)
# Create a free account at resend.com to get this API key
RESEND_API_KEY=""

# SMTP fallback (optional; used when RESEND_API_KEY is not set)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""

# Admin Initial Credentials (optional, for seeding)
# These are used only when running the seed script
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="secure_password_here"
